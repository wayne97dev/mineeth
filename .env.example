# Copy to .env and fill in. NEVER commit .env.

# Mainnet RPC (Alchemy / Infura / QuickNode)
MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Sepolia RPC (only if you want to test on testnet first)
SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Etherscan v2 API key (auto-verifies the deployed contract)
ETHERSCAN_KEY=YOUR_ETHERSCAN_API_KEY

# Uniswap V4 mainnet addresses (defaults already baked into Deploy.s.sol — override only for testnets)
# POOL_MANAGER=0x000000000004444c5dc75cB358380D2e3dE08A90
# POSITION_MANAGER=0xbD216513d74C8cf14cf4747E6AaA6420FF64ee9e
# PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3
